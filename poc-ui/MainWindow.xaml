<Window x:Class="PocWifiDirectUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WiFi Direct PoC 测试工具"
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="Bold" Margin="0,0,0,8">
            LAN Audio Bridge — WiFi Direct PoC
        </TextBlock>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Padding="12" CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusDot" Grid.Column="0" Width="16" Height="16" Fill="Gray" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="未启动" VerticalAlignment="Center" FontSize="14"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnStart" Content="▶ 启动" Width="90" Height="30" Margin="0,0,8,0" Click="OnStartClick"/>
                    <Button x:Name="BtnStop" Content="⏹ 停止" Width="90" Height="30" IsEnabled="False" Click="OnStopClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- P2P 信息 -->
        <Border Grid.Row="2" Padding="12" CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="SSID：" FontWeight="Bold" Margin="0,0,4,4"/>
                <TextBlock x:Name="TxtSsid" Grid.Row="0" Grid.Column="1" Text="-" Margin="0,0,16,4"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="密码：" FontWeight="Bold" Margin="0,0,4,4"/>
                <TextBlock x:Name="TxtPassword" Grid.Row="0" Grid.Column="3" Text="-" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="P2P IP：" FontWeight="Bold" Margin="0,0,4,4"/>
                <TextBlock x:Name="TxtIp" Grid.Row="1" Grid.Column="1" Text="-" Margin="0,0,16,4"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="监听端口：" FontWeight="Bold" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="12345 (UDP)" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Publisher：" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtPublisherStatus" Grid.Row="2" Grid.Column="1" Text="-" Grid.ColumnSpan="3"/>
            </Grid>
        </Border>

        <!-- 数据包日志 -->
        <Border Grid.Row="3" Padding="8" CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="收到数据包" FontWeight="Bold" FontSize="13"/>
                    <Button x:Name="BtnClear" Grid.Column="1" Content="清空" Width="60" Height="24" Click="OnClearClick"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="PacketList"
                             ItemsSource="{Binding}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,4" CornerRadius="4"
                                        BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                        Background="{Binding BgBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                                   Text="{Binding TimeSource}" FontSize="12"
                                                   FontWeight="Bold" Foreground="#333"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="长度：" FontSize="12" Foreground="#666"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LengthText}" FontSize="12" Foreground="#666"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="HEX：" FontSize="12" Foreground="#666"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HexText}" FontSize="11"
                                                   FontFamily="Consolas" Foreground="#0066CC"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="文本：" FontSize="12" Foreground="#666"
                                                   Visibility="{Binding HasText}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TextContent}" FontSize="12"
                                                   Foreground="#333"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 底部状态 -->
        <TextBlock x:Name="TxtFooter" Grid.Row="4" Text="就绪" FontSize="11" Foreground="#999"/>
    </Grid>
</Window>
